@using YangOne.Web.Form;
@using System.Linq;
@model YangOne.Web.Form.IForm

<link href="~/module/yogrid/resources/css/kgridstyle.css" rel="stylesheet" />

@functions {
    private string[] parseColumnTemplate(string format)
    {
        var result = format.Split(new char[] { '{', '}' });
        return result.Length == 3 ? result : new string[] { "", "", "" };
    }
}

<div id="@Model.Name" class="row">
    <div class="container">
        <form name="@Model.Name" asp-antiforgery="true" class="@Model.CssClasses" method="post" action="@Model.Action" enctype="@Model.EncType">

            @if (Model.UseTabs)
            {
                var headingSection = Model.Sections.SingleOrDefault(x => !string.IsNullOrEmpty(x.Heading));
                if (headingSection != null)
                {
                    if (!string.IsNullOrEmpty(headingSection.Heading))
                    {
                        <h2 class="formpanel-title">@headingSection.Heading</h2>
                    }
                    if (!string.IsNullOrEmpty(headingSection.SubHeading))
                    {

                        <h4 class="formpanel-subtitle">@headingSection.SubHeading</h4>
                    }
                    if (!string.IsNullOrEmpty(headingSection.HelpLine))
                    {

                        <p class="formpanel-help">@headingSection.HelpLine</p>
                    }
                }

                <div class="custom-tab-1">
                    <ul class="nav nav-tabs">
                        @for (int i = 0; i < Model.Sections.Count(); i++)
                        {
                            var formSection = Model.Sections.ElementAt(i);
                            <li class="nav-item">
                                <a class="nav-link @(i == 0 ? "active" : "")" data-bs-toggle="tab" href="#tab_@formSection.Name.Replace(" ", "").Replace(".", "")">
                                    <i class="la la-folder me-2"></i> @formSection.Name
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="tab-content">
                        @for (int i = 0; i < Model.Sections.Count(); i++)
                        {
                            var formSection = Model.Sections.ElementAt(i);
                            <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="tab_@formSection.Name.Replace(" ", "").Replace(".", "")">
                                <div class="row">
                                    <div class="col-xl-8">
                                        @foreach (var row in formSection.Rows)
                                        {
                                            <div class="@row.CssClasses">
                                                @if (row.Template != null)
                                                {
                                                    @(row.Template)
                                                }
                                                @{
                                                    int ColumnNo = row.Columns.Count();
                                                }
                                                @foreach (var column in row.Columns)
                                                {
                                                    @Html.Raw(parseColumnTemplate(column.ColumnFormat)[0])

                                                    @if (column.Template != null)
                                                    {
                                                        <div class="@column.CssClasses">@column.Template</div>
                                                        continue;
                                                    }

                                                    @if (ColumnNo > 1)
                                                    {
                                                        <div class="@column.CssClasses">
                                                            <div class="@column.Child1Class">
                                                                <div class="@column.Child2Class">
                                                                    @foreach (var control in column.Controls)
                                                                    {
                                                                        <div class="@control.Parent2Class">
                                                                            <div class="@control.Parent1Class">
                                                                                @if (control.InputType != FormInputControl.Hidden)
                                                                                {
                                                                                    <label class="@control.LabelClass" for="@control.Id">@control.DisplayName @(control.ShowFlag ? "(*)" : "")</label>
                                                                                }
                                                                                @if (!string.IsNullOrEmpty(control.Help))
                                                                                {
                                                                                    <i class="fa fa-question-circle input-description" data-bs-toggle="tooltip" title="@control.Help"></i>
                                                                                }

                                                                                @switch (control.InputType)
                                                                                {
                                                                                    case FormInputControl.Hidden:
                                                                                        <input type="hidden" value="@control.ValueFor(Model.FormModel)" name="@control.Name" @control.RenderAttributes(this.ViewContext) />
                                                                                        break;
                                                                                    case FormInputControl.CheckBox:
                                                                                        <input type="checkbox" class="form-check" id="@control.Id" name="@control.Name" value="true" @(control.ValueFor(Model.FormModel).ToString().ToLower() == "true" ? "checked" : "") @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                                        break;
                                                                                    case FormInputControl.TextBox:
                                                                                        <input name="@control.Name" type="text" class="form-control @control.CssClasses" id="@control.Id" value="@control.ValueFor(Model.FormModel)" placeholder="@control.PlaceHolder" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                                        break;
                                                                                    case FormInputControl.TextArea:
                                                                                        <textarea class="form-control @control.CssClasses" name="@control.Name" id="@control.Id" @Html.Raw(control.RenderAttributes(this.ViewContext))>@control.ValueFor(Model.FormModel)</textarea>
                                                                                        break;
                                                                                    case FormInputControl.Editor:
                                                                                        <textarea class="editor form-control @control.CssClasses" name="@control.Name" id="@control.Id" @Html.Raw(control.RenderAttributes(this.ViewContext))>@control.ValueFor(Model.FormModel)</textarea>
                                                                                        break;
                                                                                    case FormInputControl.Select:
                                                                                        <select class="form-select @control.CssClasses" name="@control.Name" @Html.Raw(control.RenderAttributes(this.ViewContext))>
                                                                                            @control.RenderControlSource(control.DataSource, Model.FormModel)
                                                                                        </select>
                                                                                        break;
                                                                                    case FormInputControl.File:
                                                                                        <input type="file" class="form-control @control.CssClasses" id="@control.Id" name="@control.Name" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                                        break;
                                                                                    case FormInputControl.Switch:
                                                                                        <div class="form-check form-switch">
                                                                                            <input class="form-check-input" type="checkbox" name="@control.Name" @(control.ValueFor(Model.FormModel).ToString().ToLower() == "true" ? "checked" : "") @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                                        </div>
                                                                                        break;
                                                                                    default:
                                                                                        <input type="text" class="form-control @control.CssClasses" id="@control.Id" name="@control.Name" value="@control.ValueFor(Model.FormModel)" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                                        break;
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        foreach (var control in column.Controls)
                                                        {
                                                            if (control.InputType != FormInputControl.Hidden)
                                                            {

                                                                <label class="@control.LabelClass" for="@control.Id">@control.DisplayName @(control.ShowFlag ? "(*)" : "")</label>
                                                            }
                                                            if (!string.IsNullOrEmpty(control.Help))
                                                            {

                                                                <i class="fa fa-question-circle input-description" data-bs-toggle="tooltip" title="@control.Help"></i>
                                                            }

                                                            @switch (control.InputType)
                                                            {
                                                                case FormInputControl.Hidden:
                                                                    <input type="hidden" value="@control.ValueFor(Model.FormModel)" name="@control.Name" @control.RenderAttributes(this.ViewContext) />
                                                                    break;
                                                                case FormInputControl.CheckBox:
                                                                    <input type="checkbox" class="form-check" id="@control.Id" name="@control.Name" value="true" @(control.ValueFor(Model.FormModel).ToString().ToLower() == "true" ? "checked" : "") @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                    break;
                                                                case FormInputControl.TextBox:
                                                                    <input name="@control.Name" type="text" class="form-control @control.CssClasses" id="@control.Id" value="@control.ValueFor(Model.FormModel)" placeholder="@control.PlaceHolder" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                    break;
                                                                case FormInputControl.TextArea:
                                                                    <textarea class="form-control @control.CssClasses" name="@control.Name" id="@control.Id" @Html.Raw(control.RenderAttributes(this.ViewContext))>@control.ValueFor(Model.FormModel)</textarea>
                                                                    break;
                                                                case FormInputControl.Editor:
                                                                    <textarea class="editor form-control @control.CssClasses" name="@control.Name" id="@control.Id" @Html.Raw(control.RenderAttributes(this.ViewContext))>@control.ValueFor(Model.FormModel)</textarea>
                                                                    break;
                                                                case FormInputControl.Select:
                                                                    <select class="form-select @control.CssClasses" name="@control.Name" @Html.Raw(control.RenderAttributes(this.ViewContext))>
                                                                        @control.RenderControlSource(control.DataSource, Model.FormModel)
                                                                    </select>
                                                                    break;
                                                                case FormInputControl.File:
                                                                    <input type="file" class="form-control @control.CssClasses" id="@control.Id" name="@control.Name" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                    break;
                                                                case FormInputControl.Switch:
                                                                    <div class="form-check form-switch">
                                                                        <input class="form-check-input" type="checkbox" name="@control.Name" @(control.ValueFor(Model.FormModel).ToString().ToLower() == "true" ? "checked" : "") @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                    </div>
                                                                    break;
                                                                default:
                                                                    <input type="text" class="form-control @control.CssClasses" id="@control.Id" name="@control.Name" value="@control.ValueFor(Model.FormModel)" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                    break;
                                                            }
                                                        }
                                                    }
                                                    @Html.Raw(parseColumnTemplate(column.ColumnFormat)[2])
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="col-xl-4">
                                        <div class="right-sidebar-sticky">
                                            <div class="filter cm-content-box box-primary">
                                                <div class="content-title"><div class="cpa">Sidebar Section</div></div>
                                                <div class="cm-content-body"><div class="card-body">Dynamic sidebar widgets can go here.</div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                @foreach (var formSection in Model.Sections)
                {
                    <div class="row">
                        <div class="col-xl-8">
                            @foreach (var row in formSection.Rows)
                            {
                                <div class="@row.CssClasses">
                                    @if (row.Template != null)
                                    {
                                        @(row.Template)
                                    }
                                    @{
                                        int ColumnNo = row.Columns.Count();
                                    }
                                    @foreach (var column in row.Columns)
                                    {
                                        @Html.Raw(parseColumnTemplate(column.ColumnFormat)[0])
                                        @if (column.Template != null)
                                        {
                                            <div class="@column.CssClasses">@column.Template</div>
                                            continue;
                                        }
                                        <div class="@column.CssClasses">
                                            <div class="@column.Child1Class">
                                                <div class="@column.Child2Class">
                                                    @foreach (var control in column.Controls)
                                                    {
                                                        <div class="@control.Parent2Class">
                                                            <div class="@control.Parent1Class">
                                                                @if (control.InputType != FormInputControl.Hidden)
                                                                {
                                                                    <label class="@control.LabelClass" for="@control.Id">@control.DisplayName @(control.ShowFlag ? "(*)" : "")</label>
                                                                }
                                                                @if (!string.IsNullOrEmpty(control.Help))
                                                                {
                                                                    <i class="fa fa-question-circle input-description" data-bs-toggle="tooltip" title="@control.Help"></i>
                                                                }
                                                                @switch (control.InputType)
                                                                {
                                                                    case FormInputControl.Hidden:
                                                                        <input type="hidden" value="@control.ValueFor(Model.FormModel)" name="@control.Name" @control.RenderAttributes(this.ViewContext) />
                                                                        break;
                                                                    case FormInputControl.CheckBox:
                                                                        <input type="checkbox" class="form-check" id="@control.Id" name="@control.Name" value="true" @(control.ValueFor(Model.FormModel).ToString().ToLower() == "true" ? "checked" : "") @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                        break;
                                                                    default:
                                                                        <input type="text" class="form-control @control.CssClasses" id="@control.Id" name="@control.Name" value="@control.ValueFor(Model.FormModel)" @Html.Raw(control.RenderAttributes(this.ViewContext)) />
                                                                        break;
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        @Html.Raw(parseColumnTemplate(column.ColumnFormat)[2])
                                    }
                                </div>
                            }
                        
                        </div>
                        <div class="col-xl-4">
                            <div class="right-sidebar-sticky">
                                <div class="filter cm-content-box box-primary">
                                    <div class="content-title"><div class="cpa">Sidebar</div></div>
                                    <div class="cm-content-body"><div class="card-body">Widgets here</div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

            <div class="d-flex justify-content-end mt-3">
                @if (!Model.HideCancelButton)
                {
                    <a href="@Model.CancelUrl" class="btn btn-default m-2">Cancel</a>
                }
                <button type="submit" class="btn btn-primary m-2"><i class="material-icons md-18">save</i> @(string.IsNullOrEmpty(Model.SubmitButtonText) ? "Save" : Model.SubmitButtonText)</button>
            </div>
            <div class="col-md-12 clearfix"><div asp-validation-summary="All" class="text-danger"></div></div>

        </form>

        <form method="post" enctype="multipart/form-data">
            <input type="file" id="editorfiles" name="files" style="display:none;" />
        </form>
    </div>
</div>

<script src="/module/kachuwagrid/resources/js/kachuwagrid.js"></script>
<script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="/assets/js/validation/_formValidationExtentions.js"></script>
