@using Microsoft.AspNetCore.Mvc.Razor
@using YangOne.Web.Form
@using YangOne.Identity.Models
@using YangOne.Web.Grid
@using YangOne.Localization
@model YangOne.BlogEngine.ViewModel.SavePostViewModel
@inject ILocaleResourceProvider LocaleResource
@{

    LocaleResource.LookUpGroupAt("Blog");
    ViewData["Title"] = @LocaleResource.Get("Blog.Post.PageTitle.New");
    var formDataSource = (FormDatasource)ViewData["FormDataSource"];
}
@*<link href="/lib/bootstrap-datepicker/css/bootstrap-datepicker.standalone.css" rel="stylesheet" />
<link href="/lib/bootstrap-datepicker/css/bootstrap-datepicker3.standalone.css" rel="stylesheet" />*@
<style>
   
    .bootstrap-tagsinput {
        width: 100% !important;
    }
</style>
<section class="container-fluid">
    <div class="row">
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

            <div class="cardform-wrapper">

                @(Html.CreateKachuwaForm<YangOne.BlogEngine.ViewModel.SavePostViewModel>("kform", Model)
                    .SetHeading("").EncType("multipart/form-data")
                    .ActionUrl("/admin/blog/post/new")
                    .CancelUrl("/admin/blog/post")
                    .CreateSection(section =>
                                            {
                                                section.Add("section1", "form-section", rows =>
                                                {
                                                    rows.Add("1strow", "row", columns =>
                                                    {
                                                        columns.Add("left", "col-md-4", @<div class="form-description">
                                                            <h4>@LocaleResource.Get("Blog.Post.Info.Title")</h4>
                                                            <p>@LocaleResource.Get("Blog.Post.Info.InfoText")</p>
                                                        </div>);
                                                        columns.Add("right", "col-md-8", control =>
                                                        {
                                                            control.Add("form-control", model => model.PostId, FormInputControl.Hidden);


                                                            control.Add("form-control keychange", x => x.Title, FormInputControl.TextBox)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.Name"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.Name"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.Name"));

                                                            control.Add("form-control urlchange", x => x.Url, FormInputControl.TextBox)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.Url"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.Url"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.Url"));

                                                            control.Add("form-control ", x => x.Categories, FormInputControl.Select, formDataSource.GetSource("Categories"))
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.Categories"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.Categories"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.Categories"));
                                                            control.Add("form-control ", x => x.ThumbnailImageFile, FormInputControl.Image)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-6")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.ThumbnailImage"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.ThumbnailImage"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.ThumbnailImage"));
                                                            control.Add("form-control ", x => x.CoverImageFile, FormInputControl.Image)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-6")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.CoverImage"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.CoverImage"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.CoverImage"));

                                                            control.Add("form-control", x => x.PublishedOn, FormInputControl.Date)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.PublishedOn"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.PublishedOn"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.PublishedOn"));
                                                            control.Add("form-control ", x => x.Tags, FormInputControl.Tag)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.Tags"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.Tags"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.Tags"));
                                                            control.Add("form-control ", x => x.RecommendationMetaTags, FormInputControl.Tag)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.RecommendationMetaTags"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.RecommendationMetaTags"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.RecommendationMetaTags"));
                                                            control.Add("form-control ", x => x.IsPublic, FormInputControl.Switch)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.IsPublic"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.IsPublic"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.IsPublic"));
                                                            control.Add("form-control ", x => x.IsActive, FormInputControl.Switch)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.IsActive"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.IsActive"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.IsActive"));
                                                            control.Add("form-control url", x => x.Content, FormInputControl.HtmlBuilder)
                                                                .SetFirstParentClass("form-group")
                                                                .SetSecondParentClass("col-md-12")
                                                                .SetHelp(LocaleResource.Get("Blog.Post.Help.Content"))
                                                                .SetPlaceHolder(LocaleResource.Get("Blog.Post.PlaceHolder.Content"))
                                                                .SetDisplayName(LocaleResource.Get("Blog.Post.Form.Content"));

                                                        }).SetFirstChildClass("forminput-section").SetSecondChildClass("row");
                                                    });
    rows.Add("12strow", "row", columns =>
    {
      columns.Add("left", "col-md-4", @<div class="form-description">
                                                                                                            <h4>@LocaleResource.Get("Blog.Info.SEO")</h4>
                                                                                                            <p>@LocaleResource.Get("Blog.Info.SEOText")</p>
                                                                                                        </div>);
                                                      columns.Add("12strow1stcol", "", @<div>
                                                                                                                                                        <input type="hidden" name="IsNew" value="true" />
                                                                                                                                                        <input type="hidden" name="OldUrl" value="" />
                                                                                                                                                        <input name="SeoType" value="article" type="hidden" />
                                                                                                                                                    </div>);
                                                                                                 columns.Add("right", "col-md-8", control =>
                                                                                                 {
                                                                                                     control.Add("form-control", model => model.SEOId, FormInputControl.Hidden);

                                                                                                     control.Add("form-control keychange", x => x.MetaTitle, FormInputControl.TextBox)
                                                                                                         .SetFirstParentClass("form-group")
                                                                                                         .SetSecondParentClass("col-md-6")
                                                                                                         .SetHelp(LocaleResource.Get("Page.Help.MetaTitle"))
                                                                                                         .SetPlaceHolder(LocaleResource.Get("Page.PlaceHolder.MetaTitle"))
                                                                                                         .SetDisplayName(LocaleResource.Get("Page.Form.MetaTitle"));
                                                                                                     control.Add("form-control urlchange", x => x.Url, FormInputControl.TextBox)
                                                                                                         .SetFirstParentClass("form-group")
                                                                                                         .SetSecondParentClass("col-md-6")
                                                                                                         .SetHelp(LocaleResource.Get("Page.Help.Url"))
                                                                                                         .SetPlaceHolder(LocaleResource.Get("Page.PlaceHolder.Url"))
                                                                                                         .SetDisplayName(LocaleResource.Get("Page.Form.Url"));
                                                                                                     control.Add("form-control", model => model.MetaDescription, FormInputControl.TextArea)
                                                                                                         .SetFirstParentClass("form-group")
                                                                                                         .SetSecondParentClass("col-md-6")
                                                                                                         .SetHelp(LocaleResource.Get("Page.Help.MetaDescription"))
                                                                                                         .SetPlaceHolder(LocaleResource.Get("Page.PlaceHolder.MetaDescription"))
                                                                                                         .SetDisplayName(LocaleResource.Get("Page.Form.MetaDescription"));
                                                                                                     control.Add("form-control", model => model.Image, FormInputControl.Image)
                                                                                                         .SetFirstParentClass("form-group")
                                                                                                         .SetSecondParentClass("col-md-6")
                                                                                                         .SetHelp(LocaleResource.Get("Page.Help.Image"))
                                                                                                         .SetPlaceHolder(LocaleResource.Get("Page.PlaceHolder.Image"))
                                                                                                         .SetDisplayName(LocaleResource.Get("Page.Form.Image"));

                                                                                                 }).SetFirstChildClass("forminput-section").SetSecondChildClass("row");
                                                                                             });

                                                                                         })
                                                                                             .SetHeading(LocaleResource.Get("Blog.Post.Form.Title.New"));
                                                                                     }))
            </div>
        </div>
    </div>
</section>
@await Component.InvokeAsync("HtmlBuilder")
@section scripts{
    <script type="text/javascript" asp-add-nonce="true">
        (function () {
            $(document).off("input", ".keychange").on("input",
                ".keychange",
                function (event) {
                    var name = $(this).val();
                    var nameWithoutSpace = name.replace(/\s\s+/g, ' ');
                    var nameWithoutSpecialChar = nameWithoutSpace.replace(/[^a-zA-Z 0-9 -]+/g, "");
                    if (this.name == "MetaTitle") {
                        $(this).val(nameWithoutSpecialChar);
                    } else
                        $(".keychange").val(nameWithoutSpecialChar);
                    $(".urlchange").val($.trim(nameWithoutSpecialChar).replace(/ /g, "-"));
                });

            $(document).off("input", ".urlchange").on("input",
                ".urlchange",
                function (event) {
                    var fulltxt = $(this).val();
                    var pagename = fulltxt.replace("/", "");
                    var pagenam2 = fulltxt.replace("/", "");
                    var nameWithoutSpace = pagename.replace(/ /g, "");
                    var dnameWithSpace = pagenam2.replace(/-/g, " ");
                    var nameWithoutSpecialChar = nameWithoutSpace.replace(/[^a-zA-Z 0-9 -]+/g, "");
                    var nameWithoutSpecialChar2 = dnameWithSpace.replace(/[^a-zA-Z 0-9 -]+/g, "");
                    $(this).val(nameWithoutSpecialChar.replace(/\-+/g, '-'));
                });

        })();


    </script>
}