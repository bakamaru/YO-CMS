@using System.Linq;
@using Kachuwa.Web
@model Kachuwa.BlogEngine.Model.PostViewModel
@{
    Layout = "_layout";
}
<style type="text/css">
    .bootstrap-tagsinput {
        width: 100%;
    }

        .bootstrap-tagsinput .tag {
            margin-right: 2px;
            color: black;
        }

     .label-info {
        background: #9c3;
    }

    .label {
        line-height: 2 !important;
    }

    #txtSearchPost {
        border-radius: 0;
    }
</style>

<link rel="stylesheet" href="//cdn.jsdelivr.net/bootstrap.tagsinput/0.4.2/bootstrap-tagsinput.css" />
<script src="//cdn.jsdelivr.net/bootstrap.tagsinput/0.4.2/bootstrap-tagsinput.min.js"></script>

<script src="https://cdn.jsdelivr.net/momentjs/2.18.1/moment.min.js"></script>

<section class="container">

    <div class="row filter-row">
        <div class="col-md-12 filter clearfix pull-right">
            <div class="input-group">
                <input type="text" class="form-control" value="@ViewData["query"]" id="txtPostSearch" placeholder="Search...">
                <span class="input-group-btn">
                    <button class="btn btn-warning" type="button" id="btnSearchPost">
                        <i class="fa fa-search"></i>
                    </button>
                </span>
                <span class="input-group-btn">
                    <button class="btn btn-primary" type="button" id="btnAddNew">
                        <i class="fa fa-plus"></i>
                    </button>
                </span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="table-responsive  col-md-12" id="sectionBlogManageViewDetails">
            <table id="mytable" class="table table-bordred table-striped">

                <thead>
                    <tr>
                        <th><input type="checkbox" id="checkall" /></th>
                        <th>Title</th>
                        <th>Tags</th>
                        <th>Author</th>
                        <th>Published On</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>

                    @foreach (var post in Model.Posts)
                        {
                    <tr data-id="@post.PostId">
                        <td><input type="checkbox" class="checkthis" /></td>
                        <td>@post.Title</td>
                        <td>@post.Tags</td>
                        <td>@post.Author</td>
                        <td>@post.PublishedOn.ToString("D")</td>
                        <td class="td-actions text-right">
                            <button type="button" rel="tooltip" title="View Profile" class="btn btn-info btn-simple btn-xs btnDetail">
                                <i class="fa fa-user"></i>
                            </button>
                            <button type="button" rel="tooltip" title="Edit Profile" class="btn btn-success btn-simple btn-xs btnEdit">
                                <i class="fa fa-edit"></i>
                            </button>
                            <button type="button" rel="tooltip" title="Remove" class="btn btn-danger btn-simple btn-xs btnDelete">
                                <i class="fa fa-times"></i>
                            </button>
                        </td>

                    </tr>
                        }

                </tbody>
            </table>
            <div class="clearfix"></div>
            <pagination api="/admin/blog/manage/@ViewData["query"]" pageSize='@Model.Pager.PageSize' rowTotal="@Model.Pager.TotalItems" page="@Model.Pager.CurrentPage"></pagination>

        </div>

        <div class="col-md-12 clearfix">
            <div id="sectionBlogAddNew" style="display:none">
                <h3>Add New Post</h3>

                <form class="form" action="#" id="BlogInfoAddNewForm" enctype="multipart/form-data">
                    <input type="hidden" value="0" id="txtPostId" />

                    <div class="form-group">
                        <label>Title </label>
                        <input type="text" value="" placeholder="Blog Title" id="BlogInfoTitle" name="BlogInfoTitle" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Blog Content:</label>
                        <textarea id="BlogInfoContent" name="BlogInfoContent"></textarea>
                    </div>

                    <div class="form-group ">
                        <label for="BlogInfoAuthor">Author</label>
                        <select class="form-control" id="BlogInfoAuthor" name="BlogInfoAuthor"></select>
                    </div>

                    <div class="form-group">
                        <label for="BlogInfoCategory">Category</label>
                        <div class="divCategory"></div>
                    </div>

                    <div class="form-group">
                        <label>URL</label>
                        <input type="text" value="" placeholder="URL" id="BlogInfoURL" name="BlogInfoURL" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Tags</label>
                        <input type="text" id="BlogInfoTags" name="BlogInfoTags" class="form-control" value="" data-role="tagsinput" />
                    </div>

                    <div class="form-group">
                        <div class="fileinput fileinput-new" data-provides="fileinput">
                            <label>Add Image</label><br/>
                            <input type="file" id="files" name="files" style="display: none;" />
                            <button class="btn btn-info btn-browse" type="button">Browse</button>

                            <input type="text" name="ProfilePicture" id="txtUploadedImagePath" value="" hidden />
                            <div class="fileinput-new thumbnail" id="profileImageDiv">
                                <img class="img-responsive custom-image" width="150px" />
                            </div>
                        </div>
                    </div>

                    <button type="button" class="btn btn-warning" id="btnBlogAddCancel">Cancel</button>
                    <button type="button" class="btn btn-primary" id="btnBlogSubmit">Submit</button>
                </form>

            </div>
        </div>
    </div>

    <div class="modal fade" id="delete" tabindex="-1" role="dialog" aria-labelledby="edit" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"><span class="glyphicon glyphicon-remove" aria-hidden="true"></span></button>
                    <h4 class="modal-title custom_align" id="Heading">Delete this post</h4>
                </div>
                <div class="modal-body">

                    <div class="alert alert-danger"><span class="glyphicon glyphicon-warning-sign"></span> Are you sure you want to delete this post?</div>

                </div>
                <div class="modal-footer ">
                    <button type="button" class="btn btn-success"><span class="glyphicon glyphicon-ok-sign"></span> Yes</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal"><span class="glyphicon glyphicon-remove"></span> No</button>
                </div>
            </div>
            <!-- /.modal-content -->
        </div>
        <!-- /.modal-dialog -->
    </div>

</section>


<link href="/resources/simplemde/simplemde.min.css" rel="stylesheet" />
<script src="/resources/simplemde/simplemde.min.js"></script>



<script src="/module/KachuwaBlogEngine/resources/js/BlogManager.js"></script>

<script>
    
    var simplemde = new SimpleMDE({ element: $("#BlogInfoContent")[0] });
   

    $(document).ready(function () {

        BlogManager({
            IsImageRequired: true
        });
        
        $("#btnAddNew").on("click", function () {
            $("#sectionBlogManageViewDetails").hide();
            $('.filter-row').hide();
            $("#sectionBlogAddNew").show();
        });
        
    });

</script>
